# Copy to .env (or .env.local) and fill in. Never commit .env.

# Supabase (required) — from your project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# LLM providers (required from P3 onward)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# CC-session ingest skill (required from P6 onward)
# Generate with: openssl rand -hex 32
NOUS_INGEST_TOKEN=
# The auth.users.id of the user the CC-session skill writes for.
NOUS_INGEST_USER_ID=
